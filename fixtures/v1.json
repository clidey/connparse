  {
    "name": "elasticsearch explicit https uri",
    "input": "elasticsearch+https://elastic:secret@es.example.com:9243/logs?api_key=abc",
    "expected": {
      "scheme": "elasticsearch",
      "type": "api",
      "authority.host": "es.example.com",
      "authority.port": 9243,
      "resource.type": "index",
      "resource.name": "logs",
      "credentials.username": "elastic",
      "credentials.password": "secret",
      "credentials.api_key": "abc",
      "options.protocol": "https",
      "options.tls": true,
      "safe": "elasticsearch+https://elastic:***@es.example.com:9243/logs?api_key=***"
    }
  },
  {
    "name": "elasticsearch plain https with provider hint",
    "provider": "elasticsearch",
    "input": "https://elastic:secret@es.example.com:9200/logs",
    "expected": {
      "scheme": "elasticsearch",
      "authority.host": "es.example.com",
      "authority.port": 9200,
      "resource.name": "logs",
      "options.protocol": "https",
      "options.tls": true,
      "safe": "https://elastic:***@es.example.com:9200/logs"
    }
  },
  {
    "name": "cockroachdb postgres compatible uri",
    "input": "cockroach://root@servername:26257/mydb?sslmode=disable",

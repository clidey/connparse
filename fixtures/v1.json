[
  {
    "name": "postgres basic auth",
    "input": "postgres://user:pass@localhost:5432/app?sslmode=require",
    "expected": {
      "scheme": "postgres",
      "type": "database",
      "authority.host": "localhost",
      "authority.port": 5432,
      "resource.type": "database",
      "resource.name": "app",
      "credentials.username": "user",
      "credentials.password": "pass",
      "query.sslmode": "require",
      "safe": "postgres://user:***@localhost:5432/app?sslmode=require"
    }
  },
  {
    "name": "postgres default port and encoded credentials",
    "input": "postgres://u%40example:p%40ss@db.example.com/app",
    "expected": {
      "authority.host": "db.example.com",
      "authority.port": 5432,
      "credentials.username": "u@example",
      "credentials.password": "p@ss",
      "resource.name": "app"
    }
  },
  {
    "name": "postgres multi host",
    "input": "postgres://host1:5432,host2:5433/app",
    "expected": {
      "authority.hosts.0.host": "host1",
      "authority.hosts.0.port": 5432,
      "authority.hosts.1.host": "host2",
      "authority.hosts.1.port": 5433,
      "resource.name": "app"
    }
  },
  {
    "name": "postgres multi host target session attributes",
    "input": "postgresql://host1:123,host2:456/somedb?target_session_attrs=any&application_name=myapp",
    "expected": {
      "scheme": "postgresql",
      "type": "database",
      "authority.hosts.0.host": "host1",
      "authority.hosts.0.port": 123,
      "authority.hosts.1.host": "host2",
      "authority.hosts.1.port": 456,
      "resource.name": "somedb",
      "query.target_session_attrs": "any",
      "query.application_name": "myapp"
    }
  },
  {
    "name": "postgres jdbc url",
    "input": "jdbc:postgresql://db.example.com:5432/app?sslmode=verify-full",
    "expected": {
      "scheme": "jdbc:postgresql",
      "authority.host": "db.example.com",
      "authority.port": 5432,
      "resource.name": "app",
      "query.sslmode": "verify-full",
      "options.jdbc": true
    }
  },
  {
    "name": "mysql database",
    "input": "mysql://root:secret@127.0.0.1/shop?charset=utf8mb4",
    "expected": {
      "scheme": "mysql",
      "type": "database",
      "authority.host": "127.0.0.1",
      "authority.port": 3306,
      "resource.name": "shop",
      "query.charset": "utf8mb4",
      "safe": "mysql://root:***@127.0.0.1/shop?charset=utf8mb4"
    }
  },
  {
    "name": "mysql jdbc url",
    "input": "jdbc:mysql://mysql.example.com:3306/shop?ssl-mode=REQUIRED",
    "expected": {
      "scheme": "jdbc:mysql",
      "authority.host": "mysql.example.com",
      "authority.port": 3306,
      "resource.name": "shop",
      "query.ssl-mode": "REQUIRED",
      "options.jdbc": true
    }
  },
  {
    "name": "mysql x protocol srv",
    "input": "mysqlx+srv://user:pass@mysql.example.com/main?auth-method=AUTO",
    "expected": {
      "scheme": "mysqlx+srv",
      "authority.host": "mysql.example.com",
      "authority.port": 3306,
      "resource.name": "main",
      "credentials.username": "user",
      "credentials.password": "pass",
      "query.auth-method": "AUTO"
    }
  },
  {
    "name": "postgres keyword value conninfo with provider hint",
    "provider": "postgres",
    "input": "host=db.example.com port=5432 dbname=app user=alice password=secret sslmode=require",
    "expected": {
      "scheme": "postgres",
      "authority.host": "db.example.com",
      "authority.port": 5432,
      "resource.name": "app",
      "credentials.username": "alice",
      "credentials.password": "secret",
      "query.sslmode": "require",
      "options.conninfo": true,
      "safe": "host=db.example.com port=5432 dbname=app user=alice password=*** sslmode=require"
    }
  },
  {
    "name": "mysql shell uri-like string with provider hint",
    "provider": "mysql",
    "input": "myuser:pass@example.com:3306/main-schema?ssl-mode=VERIFY_IDENTITY",
    "expected": {
      "scheme": "mysql",
      "authority.host": "example.com",
      "authority.port": 3306,
      "resource.name": "main-schema",
      "credentials.username": "myuser",
      "credentials.password": "pass",
      "query.ssl-mode": "VERIFY_IDENTITY"
    }
  },
  {
    "name": "mariadb jdbc sequential multi host",
    "input": "jdbc:mariadb:sequential://host1:3306,host2:3307/app?sslMode=verify-full",
    "expected": {
      "scheme": "jdbc:mariadb",
      "authority.hosts.0.host": "host1",
      "authority.hosts.0.port": 3306,
      "authority.hosts.1.host": "host2",
      "authority.hosts.1.port": 3307,
      "resource.name": "app",
      "query.sslMode": "verify-full",
      "options.jdbc": true,
      "options.mode": "sequential"
    }
  },
  {
    "name": "mariadb uri",
    "input": "mariadb://root:secret@mariadb.example.com:3306/app",
    "expected": {
      "scheme": "mariadb",
      "authority.host": "mariadb.example.com",
      "authority.port": 3306,
      "resource.name": "app",
      "credentials.username": "root",
      "credentials.password": "secret"
    }
  },
  {
    "name": "mongodb srv",
    "input": "mongodb+srv://user:pass@cluster.mongodb.net/app?retryWrites=true",
    "expected": {
      "scheme": "mongodb+srv",
      "type": "database",
      "authority.host": "cluster.mongodb.net",
      "authority.port": null,
      "resource.name": "app",
      "options.srv": true,
      "query.retryWrites": "true",
      "safe": "mongodb+srv://user:***@cluster.mongodb.net/app?retryWrites=true"
    }
  },
  {
    "name": "mongodb standard multi host",
    "input": "mongodb://user:pass@mongo1.example.com:27017,mongo2.example.com:27018/app?replicaSet=rs0&tls=true",
    "expected": {
      "scheme": "mongodb",
      "authority.hosts.0.host": "mongo1.example.com",
      "authority.hosts.0.port": 27017,
      "authority.hosts.1.host": "mongo2.example.com",
      "authority.hosts.1.port": 27018,
      "resource.name": "app",
      "query.replicaSet": "rs0",
      "query.tls": "true",
      "credentials.username": "user",
      "credentials.password": "pass"
    }
  },
  {
    "name": "redis tls",
    "input": "rediss://:pass@cache.example.com/0",
    "expected": {
      "scheme": "rediss",
      "type": "cache",
      "authority.host": "cache.example.com",
      "authority.port": 6379,
      "resource.type": "database_index",
      "resource.name": "0",
      "credentials.password": "pass",
      "options.tls": true
    }
  },
  {
    "name": "redis stackexchange config with provider hint",
    "provider": "redis",
    "input": "localhost:6379,password=secret,ssl=True,defaultDatabase=2",
    "expected": {
      "scheme": "redis",
      "authority.host": "localhost",
      "authority.port": 6379,
      "resource.name": "2",
      "credentials.password": "secret",
      "options.ssl": "True",
      "options.tls": true,
      "safe": "localhost:6379,password=***,ssl=True,defaultDatabase=2"
    }
  },
  {
    "name": "duckdb file path",
    "input": "./warehouse.duckdb",
    "expected": {
      "scheme": "duckdb",
      "type": "database",
      "resource.name": "./warehouse.duckdb",
      "path": "./warehouse.duckdb"
    }
  },
  {
    "name": "duckdb memory",
    "input": "duckdb::memory:",
    "expected": {
      "scheme": "duckdb",
      "resource.name": ":memory:",
      "path": ":memory:",
      "options.memory": true
    }
  },
  {
    "name": "duckdb uri",
    "input": "duckdb:///tmp/analytics.duckdb?access_mode=read_only",
    "expected": {
      "scheme": "duckdb",
      "path": "/tmp/analytics.duckdb",
      "query.access_mode": "read_only"
    }
  },
  {

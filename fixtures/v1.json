      "scheme": "memcached",
      "authority.host": "cache.example.com",
      "authority.port": 11212,
      "options.tls": true
    }
  },
  {
    "name": "memcached host list with provider hint",
    "provider": "memcached",
    "input": "cache1.example.com:11211,cache2.example.com",

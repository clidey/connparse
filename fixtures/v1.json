      "authority.port": 9000,
      "credentials.username": "admin",
      "credentials.password": "quest",
      "query.auto_flush_rows": "5000",
      "options.ingestion": true,
      "options.protocol": "https",
      "options.tls": true,
      "safe": "https::addr=questdb.example.com:9000;username=admin;password=***;auto_flush_rows=5000;"
    }
  },
  {
    "name": "questdb ilp multi addr tcp",

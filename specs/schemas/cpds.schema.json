{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://connparse.dev/schemas/cpds.schema.json",
  "title": "Connparse Definition Specification (CPDS) Definition",
  "type": "object",
  "required": [
    "id",
    "name",
    "type",
    "schemes",
    "adapter",
    "resource",
    "path",
    "query_parameters",
    "validation"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "type": {
      "enum": [
        "database",
        "object_storage",
        "file",
        "stream",
        "cache",
        "analytics",
        "api",
        "unknown"
      ]
    },
    "schemes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "provider_aliases": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "adapter": {
      "type": "string",
      "minLength": 1
    },
    "defaults": {
      "type": "object",
      "properties": {
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        }
      },
      "additionalProperties": true
    },
    "authority": {
      "type": "object",
      "additionalProperties": {
        "type": "boolean"
      }
    },
    "resource": {
      "$ref": "#/$defs/rule"
    },
    "path": {
      "$ref": "#/$defs/rule"
    },
    "credentials": {
      "type": "object",
      "additionalProperties": {
        "type": "boolean"
      }
    },
    "query_parameters": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/queryRule"
      }
    },
    "semantic_fields": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/semanticField"
      }
    },
    "validation": {
      "type": "object",
      "properties": {
        "require_host": {
          "type": "boolean"
        },
        "port_range": {
          "type": "object",
          "required": [
            "min",
            "max"
          ],
          "properties": {
            "min": {
              "type": "integer",
              "minimum": 1,
              "maximum": 65535
            },
            "max": {
              "type": "integer",
              "minimum": 1,
              "maximum": 65535
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "options": {
      "type": "object",
      "additionalProperties": true
    },
    "redaction": {
      "type": "object",
      "properties": {
        "safe_credentials": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "sensitive_keys": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "$defs": {
    "rule": {
      "type": "object",
      "required": [
        "type",
        "required"
      ],
      "properties": {
        "type": {
          "type": "string",
          "minLength": 1
        },
        "required": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "queryRule": {
      "type": "object",
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "enum": [
            "string",
            "boolean",
            "number"
          ]
        },
        "allowed": {
          "type": "array",
          "items": {
            "type": [
              "string",
              "number",
              "boolean"
            ]
          }
        },
        "aliases": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "normalized_values": {
          "$ref": "#/$defs/scalarMap"
        }
      },
      "additionalProperties": false
    },
    "semanticField": {
      "type": "object",
      "required": [
        "sources"
      ],
      "properties": {
        "sources": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/semanticSource"
          }
        }
      },
      "additionalProperties": false
    },
    "semanticSource": {
      "type": "object",
      "properties": {
        "from_query": {
          "type": "string",
          "minLength": 1
        },
        "from_option": {
          "type": "string",
          "minLength": 1
        },
        "from_scheme": {
          "const": true
        },
        "values": {
          "$ref": "#/$defs/scalarMap"
        }
      },
      "oneOf": [
        {
          "required": [
            "from_query"
          ]
        },
        {
          "required": [
            "from_option"
          ]
        },
        {
          "required": [
            "from_scheme"
          ]
        }
      ],
      "additionalProperties": false
    },
    "scalarMap": {
      "type": "object",
      "additionalProperties": {
        "type": [
          "string",
          "number",
          "boolean"
        ]
      }
    }
  }
}

{
  "name": "@clidey/connparse",
  "version": "0.6.0",
  "description": "Parse database connection strings, DSNs, URLs, file paths, and cloud storage URIs.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/clidey/connparse.git",
    "directory": "packages/js"
  },
